generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  role          String    @default("STUDENT")
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]
  courses       Course[]
  enrollments   Enrollment[]
  teacherProfile      TeacherProfile?
  teacherApplication  TeacherApplication?
  universityAdminOf   UniversityAdmin[]
  universityTeacherOf UniversityTeacher[]
  lessonProgress      LessonProgress[]
  sentNotifications     Notification[] @relation("SentNotifications")
  receivedNotifications Notification[] @relation("ReceivedNotifications")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// Course Model

enum CourseLevel {
  Beginner
  Intermediate
  Advanced
}

enum CourseStatus {
  Draft
  Published
  Archived
}

model Course {
  id               String       @id @default(uuid())
  title            String
  description      String
  fileKey          String
  price            Int
  duration         Int
  level            CourseLevel  @default(Beginner)
  category         String
  smallDescription String
  slug             String       @unique
  status           CourseStatus @default(Draft)
  imageUrl         String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @default(now()) @updatedAt
  user             User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String?

  modules          Module[]
  enrollments      Enrollment[]
  university       University?    @relation(fields: [universityId], references: [id])
  universityId     String?
  notifications    Notification[]

  @@map("course")
}

model Module {
  id          String   @id @default(uuid())
  title       String
  order       Int
  isPublic    Boolean  @default(false)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("module")
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  videoKey    String?
  order       Int
  duration    Int      @default(0) // in seconds
  moduleId    String
  module      Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("lesson")
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  paidAt    DateTime @default(now())
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@map("enrollment")
}

model TeacherProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teacher_profile")
}

enum ApplicationStatus {
  Pending
  Approved
  Rejected
}

model TeacherApplication {
  id        String            @id @default(uuid())
  userId    String            @unique
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String
  status    ApplicationStatus @default(Pending)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("teacher_application")
}

model LessonProgress {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

enum UniversityRequestStatus {
  Pending
  Approved
  Rejected
}

model UniversityRequest {
  id          String                  @id @default(uuid())
  name        String
  email       String
  website     String?
  description String?
  contactName String
  contactEmail String
  message     String?
  status      UniversityRequestStatus @default(Pending)
  adminNote   String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@map("university_request")
}

model University {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  email       String   @unique
  logo        String?
  description String?
  website     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admins        UniversityAdmin[]
  teachers      UniversityTeacher[]
  courses       Course[]
  notifications Notification[]

  @@map("university")
}

enum NotificationType {
  UNIVERSITY_INVITE
  COURSE_ASSIGNMENT
  GENERAL
}

enum NotificationStatus {
  PENDING
  ACCEPTED
  REJECTED
  READ
}

model Notification {
  id           String             @id @default(uuid())
  type         NotificationType   @default(GENERAL)
  status       NotificationStatus @default(PENDING)
  title        String
  message      String?
  senderId     String?
  receiverId   String
  universityId String?
  courseId     String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  sender     User?       @relation("SentNotifications", fields: [senderId], references: [id], onDelete: SetNull)
  receiver   User        @relation("ReceivedNotifications", fields: [receiverId], references: [id], onDelete: Cascade)
  university University? @relation(fields: [universityId], references: [id], onDelete: Cascade)
  course     Course?     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("notification")
}

model UniversityAdmin {
  id           String     @id @default(uuid())
  userId       String
  universityId String
  createdAt    DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([userId, universityId])
  @@map("university_admin")
}

model UniversityTeacher {
  id           String     @id @default(uuid())
  userId       String
  universityId String
  subject      String?
  createdAt    DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([userId, universityId])
  @@map("university_teacher")
}
