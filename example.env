# ===================================
# DATABASE CONFIGURATION
# ===================================
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# ===================================
# AUTHENTICATION (Better-Auth)
# ===================================
BETTER_AUTH_SECRET="generate-a-random-secret-key-here"
BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth
Auth_Github_Client_Id="your-github-client-id"
Auth_Github_Secret="your-github-client-secret"

# Google OAuth
Auth_GOOGLE_CLIENT_ID="your-google-client-id"
Auth_GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ===================================
# AWS S3 CONFIGURATION
# ===================================
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="auto"
AWS_ENDPOINT_URL_S3="https://your-s3-endpoint"
AWS_ENDPOINT_URL_IAM="https://your-iam-endpoint"

# Public S3 bucket name for images/videos
NEXT_PUBLIC_S3_BUCKET_NAME_IMAGES="your-bucket-name"

# ===================================
# PAYMENT GATEWAY (Razorpay)
# ===================================
# Use TEST credentials for development
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID="rzp_test_xxxxx"
RAZORPAY_KEY_SECRET="xxxxx"

# ===================================
# EMAIL SERVICE (Resend)
# ===================================
RESEND_API_KEY="re_xxxxx"
RESEND_DOMAIN="noreply.yourdomain.com"  # Optional, if not set uses default

# ===================================
# SECURITY (ArcJet)
# ===================================
ARCJET_KEY="ajkey_xxxxx"
ARCJET_ENV="development"  # Use "production" for production

# ===================================
# PUBLIC CONFIGURATION
# ===================================
# Local development
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Production example (update with your domain)
# NEXT_PUBLIC_APP_URL="https://yourdomain.com"
